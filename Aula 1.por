programa
{
	
	funcao inicio()
	{
//Crie um algoritmo, leia 5, calcule a soma de todos e mostre o resultado final
		real num1, num2, num3, num4, num5,soma
		escreva("Digite os seus numeros:\n ")
		leia(num1, num2, num3, num4, num5)
		soma = num1 + num2 + num3 + num4 + num5
		escreva("O resultado da sua soma e\n: ", soma)
	}
}
